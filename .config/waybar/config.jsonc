{
  "position": "top",
  "spacing": 0,
  "reload_style_on_change": true,
  "modules-left": [
    "hyprland/workspaces",
    "custom/spotify",
    "custom/sep",
    "custom/weather"
  ],
  "modules-center": [],
  "modules-right": [
    "tray",
    "custom/sep",
    "network",
    "custom/sep",
    "pulseaudio",
    "custom/sep",
    "bluetooth",
    "custom/sep",
    "battery",
    "custom/sep",
    "cpu",
    "custom/sep",
    "memory",
    "custom/sep",
    "clock"
  ],
  "tray": {
    "icon-size": 18,
    "spacing": 6
  },
  "clock": {
    "format": " {:%H:%M}",
    "format-alt": " {:%d/%m/%y}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "mounth",
      "format": {
        "mounth": "<span><b>{}</b></span>",
        "weekdays": "<span><b>{}</b></span>",
        "days": "<span><b>{}</b></span>",
        "today": "<span color='#dd0700'><b><u>{}</u></b></span>"
      }
    }
  },
  "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-muted": "muted",
      "format-icons": {
          "default": ["οÄß", "οÄ®"]
      },
      "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
      "on-click-right": "pavucontrol",
      "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ --limit 1.0",
      "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-" 
  },
  "bluetooth": {
    "format": "οäî",
    "format-disabled": "",
    "format-connected": "οäî {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "exec kitty bluetui"
  },
  "battery": {
    "interval": 60,
    "format": "{icon} {capacity}%",
    "format-icons": {
      "default": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
      "charging": "ο΅Π"
    }
  },
  "custom/sep": {
    "format": "|"
  },
  "custom/weather": {
    "format": " {text} ",
    "interval": 3600,
    "return-type": "json",
    "exec": "wayweather --get",
    "tooltip": true
  },
  "custom/spotify": {
    "format": "{}",
    "exec": "~/dotfiles/scripts/spotify.sh",
    "interval": 1,
    "on-click": "playerctl -p spotify play-pause",
    "on-scroll-up": "playerctl -p spotify next",
    "on-scroll-down": "playerctl -p spotify previous"
  },
  "network": {
    "format-disconnected": "disconnected ",
    "format-ethernet": "οà≥ ",
    "format-linked": "{ifname} (No IP)",
    "format-wifi": " ο΅Ϊ  {essid} ",
    "tooltip-format": "Connected to {essid} {ifname} via {gwaddr}",
    "on-click": "kitty gazelle"
  },
  "cpu": {
    "format": "ο£Φ  {usage}%",
    "interval": 1,
    "on-click": "kitty btop"
  },
  "memory": {
    "format": "νΩÖ  {percentage}%",
    "interval": 10,
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}GB",
    "on-click": "kitty btop"
  }
}
